{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TagWave",
  "version": "0.2.0",
  "identifier": "com.bitran.tagwave",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TagWave",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "http": {
      "scope": {
        "allow": [
          { "url": "https://accounts.spotify.com/**" },
          { "url": "https://api.spotify.com/**" },
          { "url": "https://itunes.apple.com/**" },
          { "url": "https://ws.audioscrobbler.com/**" }
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
